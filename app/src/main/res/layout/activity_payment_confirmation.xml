<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slx_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:background="@drawable/bg_logo_circle"
        android:contentDescription="@string/payment_success_title"
        android:padding="10dp"
        android:src="@drawable/skillex_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/payment_success_title"
        android:textColor="@color/slx_text_main"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPaymentConfirmation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/slx_text_sub" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueLearning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/continue_learning" />
</LinearLayout>

