<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MAD_POP" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/slx_primary</item>
        <item name="colorPrimaryVariant">@color/slx_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/slx_secondary</item>
        <item name="colorSecondaryVariant">@color/slx_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/slx_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/slx_primary_dark</item>
        <item name="android:windowBackground">@color/slx_bg</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/white</item>
    </style>

    <style name="Theme.MAD_POP.Launcher" parent="Theme.MAD_POP">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/white</item>
    </style>
</resources>